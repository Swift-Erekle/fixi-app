{
  "expo": {
    "name": "MyFix",
    "slug": "fixi-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "primaryColor": "#ff6b2b",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f13"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ge.fixi.app",
      "buildNumber": "1.0.3"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f13"
      },
      "package": "ge.fixi.app",
      "versionCode": 4,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "./plugins/withReactNativeFirebase",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "MyFix-ს სჭირდება მიკროფონი ხმოვანი შეტყობინებებისთვის"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MyFix-ს სჭირდება ფოტოს ასარჩევად პროფილისა და მუშაობის სანახავად",
          "cameraPermission": "MyFix-ს სჭირდება კამერა ფოტოების გადასაღებად"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ff6b2b",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "apiBase": "https://www.myfix.ge/",
      "updateRepo": "Swift-Erekle/fixi-app",
      "eas": {
        "projectId": "4bced91c-cdf4-4714-a6a3-d472a16e86ed"
      }
    }
  }
}
